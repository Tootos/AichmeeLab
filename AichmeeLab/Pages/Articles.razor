@page "/articles/feed/{Action?}"
@using AichmeeLab.Pages.Includes
@implements IDisposable 
@inject NavigationManager NavigationManager
@inject AichmeeLab.Services.UserService.IUserService UserService

<div class="viewport-center">
    <div class="search-container">
        <SearchBar OnSearchPerformed="StateHasChanged"/>
    </div>
    @if(UserService.Articles == null || UserService.Articles.Count == 0){
        <span>Loading....</span>
    }else{
        <div class="articles-list">
         @foreach(var article in UserService.Articles){
            <div class="article-slide shadow-sm">
            <div class="slide-content">
                <h2 class="article-title">@article.Title</h2>
                <p class="article-description">@article.Description</p>
                <div class="slide-meta">
                    <span class="date-label">Published</span>
                        <span class="date-value">@article.DatePublished.ToString("dd MMM yyyy")</span>
                        
                        <span class="date-divider">/</span>
                        
                        <span class="date-label">Updated</span>
                        <span class="date-value">@article.LastUpdate.ToString("dd MMM yyyy")</span>
                </div>
                    <a href="/article/@article.Id" class="read-more-link">
                        Read More <i class="bi bi-chevron-right"></i>
                    </a>
            </div>
            </div>
            }
        <Pagination CurrentPage="UserService.CurrentPage" PageSize="UserService.PageSize"
                PageCount="UserService.PageCount"
                OnPageChanged="HandleChangePage"/>
</div>
    

    }        

</div>

@code{
[Parameter]
public string? Action { get; set; }
[Parameter]
[SupplyParameterFromQuery]
public int? page { get; set; } 
string _message {get;set; } = string.Empty;

    protected override void OnInitialized()
    {
        UserService.ListChanged += StateHasChanged;
    }

        public void Dispose()
    {
        UserService.ListChanged -= StateHasChanged;
    }


 protected override async Task OnParametersSetAsync()
    {
       _message = "Loading...";

       LoadList();

       UserService.CurrentPage = page ?? 1;
        await UserService.GetArticlesAsync(); 
        
        if (UserService.Articles == null ||UserService.Articles.Count == 0)
        {
            _message = "No articles found.";
        }

        StateHasChanged();

    }

    protected void LoadList()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        UserService.SearchTerm = query.TryGetValue("q", out var q) ? q.ToString() : "";

        if (query.TryGetValue("from", out var f) && DateTime.TryParse(f, out var df))
            UserService.DateFrom = df;
        else
            UserService.DateFrom = null;

        if (query.TryGetValue("to", out var t) && DateTime.TryParse(t, out var dt))
            UserService.DateTo = dt;
        else
            UserService.DateTo = null;

        UserService.CurrentPage = query.TryGetValue("page", out var p) && int.TryParse(p, out var pg) ? pg : 1;
    }


    
    private void HandleChangePage(int page)
    {
        // Use the helper to keep current search/dates but change only the page
        var uri = NavigationManager.GetUriWithQueryParameter("page", page);
        NavigationManager.NavigateTo(uri);
    }
    
    
    

}

