@page "/admin/articles/"
@using AichmeeLab.Pages.Includes
@using AichmeeLab.Layout.LayoutElements.SearchBar 
@using System.Net.Security
@implements IDisposable
@inject NavigationManager NavigationManager;
@inject AichmeeLab.Services.WriterService.IWriterService WriterService;
@inject AichmeeLab.Services.SecurityService.ISecurityService SecurityService;

<div class="admin-window">

    <div class="admin-layout">
        <div class="view-switcher-header">
            <div class="btn-group w-100" role="group">
                <button type="button" class="btn @(selectedTab == Tab.List ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SwitchToTab(Tab.List)">
                    <i class="bi bi-grid-3x3-gap"></i> Article List
                </button>
                <button type="button" class="btn @(selectedTab == Tab.Article ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => SwitchToTab(Tab.Article)">
                    <i class="bi bi-pencil-square"></i> @(string.IsNullOrEmpty(SelectedArticle.Title) ? "Publish New" : SelectedArticle.Title)
                </button>
            </div>
        </div>


        @switch (selectedTab)
        {
            case Tab.List:
                <div class="search-container">
                    <SearchBar OnSearchPerformed="LoadList" />
                </div>
                <ArticlesList OnEditRequested="HandleEditRequestAsync" />

                break;
            case Tab.Article:

                <ArticlesEdit SelectedArticle="@SelectedArticle" OnReady="StateHasChanged" OnChange="HandleChange" />
                break;
        }

    </div>
</div>
@code {
    enum Tab { List, Article }
    Tab selectedTab = Tab.List;

    Article SelectedArticle = new Article();


    protected override async Task OnInitializedAsync()
    {
        if (!await SecurityService.IsAuthorizedAsync())
            NavigationManager.NavigateTo("/unauthorized/");

    }
    //Listener set up
    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
    }
    // Initial loading
    protected override void OnParametersSet()
    {
        LoadList();
    }
    //This runs every time the URL changes
    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        LoadList();
        StateHasChanged();
    }

    //ArticleList: Get data from service
    protected void LoadList()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        WriterService.SearchTerm = query.TryGetValue("q", out var q) ? q.ToString() : "";

        if (query.TryGetValue("from", out var f) && DateTime.TryParse(f, out var df))
            WriterService.DateFrom = df;
        else
            WriterService.DateFrom = null;

        if (query.TryGetValue("to", out var t) && DateTime.TryParse(t, out var dt))
            WriterService.DateTo = dt;
        else
            WriterService.DateTo = null;

        WriterService.CurrentPage = query.TryGetValue("page", out var p) && int.TryParse(p, out var pg) ? pg : 1;
    }
    //Clean up to avoid memory leaks
    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    //Switching to Editor
    private async Task HandleEditRequestAsync(string id)
    {
        var response = await WriterService.GetArticleAsync(id);
        if (response != null && response.Data != null)
        {
            SelectedArticle= response.Data;
            selectedTab = Tab.Article;
            StateHasChanged();
        }

    }

    void HandleChange(Article article)
    {
        SelectedArticle = article;

        StateHasChanged();

    }
    //Switch Tab
    void SwitchToTab(Tab tab) => selectedTab = tab;

}