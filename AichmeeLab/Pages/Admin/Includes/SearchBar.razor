@inject NavigationManager NavigationManager;
@inject AichmeeLab.Services.DashboardService.IDashboardService DashboardService;

<div class="card shadow-sm mb-4 border-0 bg-light">
    <div class="card-body">
        <div class="row g-3 align-items-end">

            @* 1. Search Field *@
            <div class="col-lg-4 col-md-6">
                <label class="form-label small fw-bold text-uppercase text-muted">Keywords</label>
                <input type="text"
                       class="form-control"
                       placeholder="Search by term"
                       @bind="_searchTerm"
                       @bind:event="oninput"
                       @ref="searchInput"
                       @onkeyup="HandleKeyUp" />
            </div>

            @* 2. Date From *@
            <div class="col-lg-2 col-md-3 col-6">
                <label class="form-label small fw-bold text-uppercase text-muted">From</label>
                <input type="date"
                       class="form-control"
                       @bind="_dateFrom" />
            </div>

            @* 3. Date To *@
            <div class="col-lg-2 col-md-3 col-6">
                <label class="form-label small fw-bold text-uppercase text-muted">To</label>
                <input type="date"
                       class="form-control"
                       @bind="_dateTo" />
            </div>

            @* 4. Actions *@
            <div class="col-lg-4 col-md-12 d-flex gap-2">
                <button class="btn btn-primary w-100" @onclick="HandleSearch">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>

        </div>
    </div>
</div>

@code {
    string _searchTerm { get; set; } = string.Empty;
    DateTime? _dateFrom { get; set; }
    DateTime? _dateTo { get; set; }

    protected ElementReference searchInput;

    protected override async Task OnAfterRenderAsync(bool firstRender)//Autofocus method
    {
        if (firstRender)
        {
            await searchInput.FocusAsync();
        }
    }



    void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            HandleSearch();
    }
    void HandleSearch()
    {
       
        var parameters = new Dictionary<string, object?>
        {
            ["q"] = string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm,
            ["from"] = _dateFrom?.ToString("yyyy-MM-dd"),
            ["to"] = _dateTo?.ToString("yyyy-MM-dd"),
            ["page"] = 1
        };

        var baseUri = $"/admin/articles/search";
        var uri = NavigationManager.GetUriWithQueryParameters(baseUri, parameters);
        NavigationManager.NavigateTo(uri, forceLoad: false);
    }
}
