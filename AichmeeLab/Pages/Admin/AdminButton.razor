@implements IDisposable

@inject AichmeeLab.Services.SecurityService.ISecurityService SecurityService;
@inject NavigationManager NavigationManager


    @if(_isAdmin){
    <div class="admin-quick-access">
        <a href="/admin
        " class="btn-admin-gear">
            <i class="bi bi-gear-fill"></i>
        </a>
    </div>
    }

@code{
        private bool _isAdmin {get; set; }= false;

    protected override async Task OnInitializedAsync()
    {
       _isAdmin = await SecurityService.IsAuthorizedAsync();
       NavigationManager.LocationChanged += HandleLocationChangedAsync;
    }  

    private async void HandleLocationChangedAsync(object? sender, LocationChangedEventArgs e)
    {
        _isAdmin = await SecurityService.IsAuthorizedAsync();

        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChangedAsync;
    }
}