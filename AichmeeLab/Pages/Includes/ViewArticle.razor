@using System.Text.Json
@using Aichmee.Shared;

@inject AichmeeLab.Services.UserService.IUserService UserService


<div class="view-window">
    <div class="view-layout">
    <div class="top-footer">
        <a href="/" class="close-btn"><i class="bi bi-x-lg"></i></a>
    </div>
    <div class="article-content">
        <div class= "header-wrapper">
            <h1 class="view-title">@SelectedArticle.Title</h1>
            <h3 class="view-author">by @SelectedArticle.Author</h3>
        <span class="view-date">Date Published:@SelectedArticle.DatePublished.ToString("MMM dd, yyyy")
            | Last Updated: @SelectedArticle.LastUpdate.ToString("MMM dd, yyyy")</span>
        </div>

    @if (HeaderImage != null && !string.IsNullOrEmpty(HeaderImage.StorageUrl))
        {
            <div class="view-img">
                <img src="@HeaderImage.StorageUrl" alt="@SelectedArticle.Title" class="img-fluid rounded shadow-sm" />
            </div>
        }     

        <div class="media-body">
            <p class="view-description">@SelectedArticle.Description</p>

            @if (parsedContent?.Blocks != null)
            {
                @foreach (var block in parsedContent.Blocks)
                {
                    @if (block.Type == "paragraph")
                    {
                        <p>@((MarkupString)block.Data.Text)</p>
                    }
                    else if (block.Type == "header")
                    {
                        @* You can check block.Data.Level here if needed *@
                        <h3>@((MarkupString)block.Data.Text)</h3>
                    }
                }
            }
        </div>
    </div>
    </div>
</div>



@code {
    [Parameter]
    public Article SelectedArticle { get; set; } = new Article();
    [Parameter]
    public Image HeaderImage { get; set; } = new Image();

    EditorJsData? parsedContent;

    public class EditorJsData { public List<EditorJsBlock> Blocks { get; set; } = new(); }

    public class EditorJsBlock
    {
        public string Type { get; set; } = string.Empty;
        public EditorJsDataContent Data { get; set; }
    }

    public class EditorJsDataContent { public string Text { get; set; } = string.Empty; }

    string _message { get; set; } = "Loading. . .";



    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(SelectedArticle.Content))
        {
            try
            {
                parsedContent = JsonSerializer.Deserialize<EditorJsData>(SelectedArticle.Content,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            catch
            {
                _message = "Error parsing article content.";
            }
        }
    }
}