@using System.Text.Json
@using Aichmee.Shared;
@using System.Text.Json.Serialization
@using BootstrapBlazor.Components

@inject AichmeeLab.Services.UserService.IUserService UserService


<div class="view-window">
    <div class="view-layout">
        <div class="top-footer">
            <a href="/" class="close-btn"><i class="bi bi-x-lg"></i></a>
        </div>
        <div class="article-content">
            <div class="header-wrapper">
                <h1 class="view-title">@SelectedArticle.Title</h1>
                <h3 class="view-author">by @SelectedArticle.Author</h3>
                <span class="view-date">Date Published:@SelectedArticle.DatePublished.ToString("MMM dd, yyyy")
                    | Last Updated: @SelectedArticle.LastUpdate.ToString("MMM dd, yyyy")</span>
                </div>

                @if (HeaderImage != null && !string.IsNullOrEmpty(HeaderImage.HeaderUrl))
                {
                    <div class="view-img">
                        <img src="@HeaderImage.HeaderUrl" alt="@HeaderImage.RawImageUrl" class="img-fluid rounded shadow-sm" />
                    </div>
                }

                <p class="view-description">@SelectedArticle.Description</p>

                @foreach (var block in SelectedArticle.ContentBlocks.OrderBy(x => x.Step))
                {
                    @if (block.Type == "text")
                    {
                        @* The 'Reader-Side' fix: ensure content is wrapped if it's raw text *@
                        <div class="view-text-block">
                            @((MarkupString)FormatContent(block.Content))
                        </div>
                    }
                    else if (block.Type == "collage")
                    {
                        @* We will build this next, but for now, it's ready for images *@
                        <div class="view-collage-block">
                        </div>
                    }
                }
            </div>
        </div>
    </div>



@code {
    [Parameter]
    public Article SelectedArticle { get; set; } = new Article();
    [Parameter]
    public Image HeaderImage { get; set; } = new Image();

    public class ListItem
    {
        public string? Content { get; set; }
        public List<ListItem>? Items { get; set; } // This allows for dots inside dots
    }

    private string FormatContent(string content)
    {
        if (string.IsNullOrWhiteSpace(content)) return "";
        
        var trimmed = content.Trim();
        // If it doesn't start with a tag, wrap it in a <p> for safety
        if (!trimmed.StartsWith("<"))
        {
            return $"<p>{trimmed}</p>";
        }
        return trimmed;
    }

}