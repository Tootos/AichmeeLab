@using AichmeeLab.Pages.Includes.ImageManager
@using AichmeeLab.Services.PhotographerService
@inject IJSRuntime jSRuntime;
@inject AichmeeLab.Services.WriterService.IWriterService WriterService;
@inject AichmeeLab.Services.PhotographerService.IPhotographerService PhotographerService;

<div class="editor-layout">
    @if (_isPreviewMode)
    {
        <button type="button" class="btn btn-outline-secondary" @onclick="TogglePreviewAsync">
            <i class="bi bi-arrow-left me-1"></i>
        </button>
        <ViewArticle SelectedArticle="SelectedArticle" HeaderImage="_selectedImage"/>
    }
    else
    {
        <div class="editor-container">
            <div class="header-image-manager @(_isHeaderOpen ? "is-open" : "is-closed")">
                <div class="manager-toggle" @onclick="HandleHeaderOpeningAsync">
                    <span><i class="bi bi-image me-2"></i> ARTICLE HEADER</span>
                    <i class="bi @(_isHeaderOpen ? "bi-chevron-up" : "bi-chevron-down")"></i>
                </div>

                <div class="split-view">
                    @if (_isHeaderOpen)
                    {
                        <div class="meta-container">

                            <div class="field-group">
                                <InputText @bind-Value="SelectedArticle.Title" class="inspector-field"
                                           placeholder="Title. . ." />
                            </div>

                            <div class="field-group">
                                <InputText @bind-Value="SelectedArticle.Author" class="inspector-field"
                                           placeholder="Author. . ." />
                            </div>

                            <div class="field-group">
                                <InputTextArea @bind-Value="SelectedArticle.Description" class="description-field"
                                               placeholder="Description" />

                            </div>


                        </div>

                        <div class="image-wrapper">
                            @if (_selectedImage != null && !string.IsNullOrWhiteSpace(_selectedImage.StorageUrl) && !_isFetchingImage)
                            {
                                <div class="header-preview-container" @onclick="() => _showImageManager = true">
                                    
                                    <img src="@_selectedImage.StorageUrl" class="img-fluid rounded" />
                                    <div class="hover-overlay">
                                        <i class="bi bi-pencil-square"></i> Change Header
                                    </div>
                                    
                                </div>
                            }
                            else if (_isFetchingImage)
                            {
                                <div class="loader-placeholder">Loading Image...</div>
                            }
                            else
                            {
                                <button type="button" class="btn-add-header" @onclick="() => _showImageManager = true">
                                    <i class="bi bi-plus-circle-dotted"></i>
                                    <span>Add Header Image</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="editor-canvas" @key="@(SelectedArticle.Id ?? "new article")">
                <div id="editorjs"></div>
            </div>

        </div>


        <div class="action-container">
            <EditForm Model="SelectedArticle" OnValidSubmit="SaveEntryAsync" class="form-wrapper">
                <DataAnnotationsValidator />

                <ValidationMessage For="@(() => SelectedArticle.Title)" />
                <ValidationMessage For="@(() => SelectedArticle.Description)" />
                <ValidationMessage For="@(() => SelectedArticle.Author)" />
                <button type="button" class="btn btn-primary" @onclick="TogglePreviewAsync">
                    <i class="bi bi-eye"></i>Preview
                </button>
                <button type="button" class="btn btn-primary" @onclick="ResetEditorAsync">
                    <i class="bi-arrow-clockwise"></i> Create New
                </button>

                <div class="form-check form-switch visibility-control">
                    <input type="checkbox" class="btn-check" id="vSwitch" @bind="SelectedArticle.IsVisible"
                           autocomplete="off">
                        <label
                            class="btn @(SelectedArticle.IsVisible ? "btn-success" : "btn-outline-secondary") w-100 py-2 fw-bold"
                            for="vSwitch">
                            <i class="bi @(SelectedArticle.IsVisible ? "bi-eye-fill" : "bi-eye-slash") me-1"></i>
                            @(SelectedArticle.IsVisible ? "VISIBLE" : "HIDDEN")
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mb-2">
                        <i class="bi bi-cloud-arrow-up-fill me-1"></i> Save Article
                    </button>

                    @if (!string.IsNullOrEmpty(SelectedArticle.Id))
                    {
                        <button type="button" class="btn btn-outline-danger btn-sm w-100 border-0 mt-2"
                                @onclick="DeleteFromDbAsync">
                            Delete from Database
                        </button>
                    }
                </EditForm>
            </div>

        }
    </div>

    @if (_showImageManager)
    {
        <ImageWindowManager OnConfirm="HandleHeaderSelected" OnCancel="() => _showImageManager = false" />
    }
@code {
    [Parameter] public Article SelectedArticle { get; set; } = new Article();
    Image? _selectedImage { get; set; }
    [Parameter] public EventCallback OnReady { get; set; }
    [Parameter] public EventCallback<Article?> OnChange { get; set; }
    bool _isPreviewMode { get; set; } = false;
    bool _showImageManager { get; set; } = false;
    bool _jsIsReady { get; set; }
    string? _lastId;
    bool _isHeaderOpen { get; set; } = false;
    bool _isFetchingImage { get; set; } = false;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // 1. Exit if we are in preview mode
        if (_isPreviewMode) return;

        // 2. Only initialize if the ID has changed or it's the first time
        if (_lastId != SelectedArticle.Id || (_lastId == null && !_jsIsReady))
        {
            _lastId = SelectedArticle.Id;
            _jsIsReady = true;

            await Task.Delay(50);
            await jSRuntime.InvokeVoidAsync("setupEditor", "editorjs", SelectedArticle.Content);
        }
    }
    public async Task SaveEntryAsync()
    {

        var jsonResult = await jSRuntime.InvokeAsync<string>("saveEditorData");
        SelectedArticle.Content = jsonResult;

        var response = await WriterService.UpdateArticleAsync(SelectedArticle);
        if (response.Success && response.Data != null)
            SelectedArticle = response.Data;


        await jSRuntime.InvokeVoidAsync("alert", response.Message);

        await OnChange.InvokeAsync(SelectedArticle);

    }

    async Task ResetEditorAsync()
    {
        await jSRuntime.InvokeVoidAsync("destroyEditor");

    
        _jsIsReady = false;
        _lastId = null;
        SelectedArticle = new Article
        {
            Content = "{\"blocks\":[]}"
        };
        _selectedImage = null;

        await OnChange.InvokeAsync(SelectedArticle);
        StateHasChanged();
    }

    async Task TogglePreviewAsync()
    {
        if (!_isPreviewMode)
        {
            SelectedArticle.Content = await jSRuntime.InvokeAsync<string>("saveEditorData");
            await jSRuntime.InvokeVoidAsync("destroyEditor");
        
            _jsIsReady = false;
            _lastId = null; // Resetting this ensures OnAfterRender runs setupEditor again
        }

        _isPreviewMode = !_isPreviewMode;
        StateHasChanged();
    }

    async Task HandleHeaderOpeningAsync()
    {
        _isHeaderOpen = !_isHeaderOpen;
        
        if(!_isHeaderOpen || string.IsNullOrEmpty(SelectedArticle.HeaderImageId)) return;

        if (_selectedImage !=null && SelectedArticle.HeaderImageId == _selectedImage?.Id) return;

        _isFetchingImage = true;
        StateHasChanged();

        var result = await PhotographerService.GetImageAsync(SelectedArticle.HeaderImageId);

        if (result.Success && result.Data != null)
            _selectedImage = result.Data;

        _isFetchingImage = false;
        StateHasChanged();

    }

    private void HandleHeaderSelected(Image selected)
    {
        _selectedImage = selected;
        SelectedArticle.HeaderImageId = selected.Id;
        _showImageManager = false;
        StateHasChanged();
    }

    async Task DeleteFromDbAsync()
    {
        if (string.IsNullOrEmpty(SelectedArticle.Id)) return;

        var response = await WriterService.DeleteArticleAsync(SelectedArticle.Id);
        await jSRuntime.InvokeVoidAsync("alert", response.Message);

        await ResetEditorAsync();

    }
}