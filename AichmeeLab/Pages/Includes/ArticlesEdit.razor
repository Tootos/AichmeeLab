@inject IJSRuntime jSRuntime;
@inject AichmeeLab.Services.DashboardService.IDashboardService DashboardService;

<div class="editor-layout">
     <div class="editor-toolbar">
            <h4 class="fw-bold m-0">Editor</h4>
            <button type="button" class="btn-link-action" @onclick="ResetEditorAsync">
                <i class="bi bi-plus-lg"></i> Create New
            </button>
        </div>
        <div class="editor-wrapper">
            <div id="editorjs" style="border: 1px solid black;"></div>
        </div>
    

    <div class="metadata-container">
            <EditForm Model="SelectedArticle" OnValidSubmit="SaveEntryAsync">
                <DataAnnotationsValidator />

                <span class="inspector-label">Article Meta</span>

                <div class="mb-3">
                    <label class="x-small fw-bold text-muted d-block">TITLE</label>
                    <InputText @bind-Value="SelectedArticle.Title" class="article-title-input" placeholder="Enter title..." />
                    <ValidationMessage For="@(() => SelectedArticle.Title)" />
                </div>

                <div class="mb-3">
                    <label class="x-small fw-bold text-muted d-block">DESCRIPTION</label>
                    <InputTextArea @bind-Value="SelectedArticle.Description" class="article-description-input" placeholder="Brief summary..." />
                    <ValidationMessage For="@(() => SelectedArticle.Description)" />
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-12">
                        <label class="x-small fw-bold text-muted d-block">AUTHOR</label>
                        <InputText @bind-Value="SelectedArticle.Author" class="form-control form-control-sm" />
                    </div>
                </div>

                <div class="form-check form-switch mb-4 bg-light p-2 rounded ps-5">
                    <input class="form-check-input" type="checkbox" role="switch" id="vSwitch" @bind="SelectedArticle.IsVisible">
                    <label class="form-check-label fw-bold small ms-2" for="vSwitch">VISIBLE</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mb-2">
                    <i class="bi bi-cloud-arrow-up-fill me-1"></i> Save Article
                </button>

                @if (IsEditMode)
                {
                    <button type="button" class="btn btn-outline-danger btn-sm w-100 border-0 mt-2" @onclick="DeleteFromDbAsync">
                        Delete from Database
                    </button>
                }
            </EditForm>
        </div>
    </div>

@code {
    [Parameter] public string? id { get; set; }
    [Parameter] public Article SelectedArticle { get; set; } = new Article();
    [Parameter] public EventCallback OnReady { get; set; }
    [Parameter] public EventCallback OnReset { get; set; }

    public bool IsEditMode => !string.IsNullOrEmpty(SelectedArticle.Id);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(100); // Give JS a moment to breathe
            await jSRuntime.InvokeVoidAsync("setupEditor", "editorjs", SelectedArticle.Content);
            await OnReady.InvokeAsync();
        }
    }

    // Triggered when clicking an article in the list
    protected override async Task OnParametersSetAsync()
    {
        // Important: Only update JS if the editor is already initialized
        await jSRuntime.InvokeVoidAsync("updateEditorData", SelectedArticle.Content);
    }

    public async Task SaveEntryAsync()
    {
        var jsonResult = await jSRuntime.InvokeAsync<string>("saveEditorData");
        SelectedArticle.Content = jsonResult;

        var response = await DashboardService.UpdateArticleAsync(SelectedArticle);
        await jSRuntime.InvokeVoidAsync("alert", response.Message);
    }

    async Task ResetEditorAsync() 
    {
        await jSRuntime.InvokeVoidAsync("updateEditorData", string.Empty);

        await OnReset.InvokeAsync();
    }

    async Task DeleteFromDbAsync() { 

        if(string.IsNullOrEmpty(SelectedArticle.Id)) return;

         var response =  await DashboardService.DeleteArticleAsync(SelectedArticle.Id);
         await jSRuntime.InvokeVoidAsync("alert", response.Message);

        await ResetEditorAsync();
 
     }
}